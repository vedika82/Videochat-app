<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Defines character encoding -->
    <meta charset="UTF-8">

    <!-- Makes website responsive on different screen sizes -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Title shown in browser tab -->
    <title>videochat app</title>

    <!-- Links external CSS file -->
    <link rel="stylesheet" href="style.css" />

    <!-- Socket.IO library for real-time communication -->
    <script src="/socket.io/socket.io.js"></script>

    <!-- Font Awesome icons library -->
    <script src="https://kit.fontawesome.com/c939d0e917.js"></script>
    <script src="https://unpkg.com/peerjs@1.3.1/dist/peerjs.min.js"></script>

    <script>
        // EJS variable
        // roomId comes from backend and is stored in ROOM_ID
        const ROOM_ID = "<%= roomId %>";
    </script>

    
</head>
<body>

     <!-- Header section -->
     <div class="header">

      <!-- Logo section -->
      <div class="logo">

        <!-- Back button -->
        <div class="header_back">
          <i class="fas fa-angle-left"></i>
        </div>
        <h3>Video Chat</h2>
      </div>
    </div>  

      <!-- Main content area -->
      <div class="main">  
    <!-- Left section for videos -->
    <div class="main_left">

      <!-- Group of videos -->
      <div class="videos_group">

        <!-- Video grid where video streams will be added dynamically -->
        <div id="video-grid">
          
        </div>
      </div>

      <!-- Buttons section -->
      <div class="options">

      <!-- Left side buttons -->
      <div class="option_left">

          <!-- Stop video button -->
          <div id="stopVideo" class="options_button">

            <!-- Camera icon -->
            <i class="fa fa-video-camera"></i>

            <!-- for using camera use this --> 
          </div>

          <!-- Mute microphone button -->
          <div id="muteButton" class="options_button">

            <!-- Microphone icon -->
            <i class="fa fa-microphone"></i>
          </div>

          <!-- Disconnect call button -->
          <div id="disconnect" class="options_button background_red">

            <!-- Phone icon -->
            <i class="fa fa-phone"></i>
          </div>

        <!-- Right-side options -->
        <div class="options_right">

          <!-- Invite user button -->
          <div id="inviteButton" class="options_button">

            <!-- Add user icon -->
            <i class="fas fa-user-plus"></i>
          </div> 
      </div>
      </div>


  <!-- Right section for chat -->
  <div class="main_right">

    <!-- Chat window -->
    <div class="main_chat_window">

      <!-- Messages container -->
      <div class="messages">

      </div>
    </div>

    <!-- Message input section -->
    <div class="main_message_container">

      <!-- Input field for typing messages -->
      <input type="text" autocomplete="off" id="chat_message" placeholder="type message here...">

      <!-- Send button -->
      <div id="send" class="option_button"> 

        <!-- Plus icon -->
        <i class="fa fa-plus" aria-hidden="true"></i> 
      </div>
    </div>
  </div>

</body>

<!-- External JavaScript file -->
<!-- Contains main logic for video chat -->
<script src="script.js"></script>

</html>